{
  "rules": {
    "shaker": {

      "products": {
        ".read":  "auth != null",
        ".write": "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin' && root.child('shaker/users').child(auth.uid).child('active').val() === true"
      },

      "inventory": {
        ".read":  "auth != null",
        ".write": "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin' && root.child('shaker/users').child(auth.uid).child('active').val() === true",
        "$itemId": {
          ".validate": "newData.hasChildren(['productId','color','size','stock'])",
          "stock": { ".validate": "newData.isNumber() && newData.val() >= 0" }
        }
      },

      "orders": {
        ".read": "auth != null && (root.child('shaker/users').child(auth.uid).child('role').val() === 'admin' || root.child('shaker/users').child(auth.uid).child('role').val() === 'moderator')",
        "$orderId": {
          ".write": "auth != null && (root.child('shaker/users').child(auth.uid).child('role').val() === 'admin' || (!data.exists() && newData.child('moderatorUid').val() === auth.uid) || (data.exists() && data.child('moderatorUid').val() === auth.uid && root.child('shaker/users').child(auth.uid).child('role').val() === 'moderator'))",
          ".validate": "newData.hasChildren(['id','customer','phone','status','date','total'])",
          "total": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "status": { ".validate": "newData.val() === 'Pending' || newData.val() === 'Confirmed' || newData.val() === 'Shipped' || newData.val() === 'Delivered' || newData.val() === 'Cancelled' || newData.val() === 'Returned'" }
        }
      },

      "marketers": {
        ".read":  "auth != null",
        ".write": "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin'"
      },

      "shipping": {
        ".read":  "auth != null",
        ".write": "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin'"
      },

      "nextBillNumber": {
        ".read":    "auth != null",
        ".write":   "auth != null",
        ".validate":"newData.isNumber() && newData.val() >= 100000000"
      },

      "users": {
        ".read":  "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin'",
        "$uid": {
          ".read":  "auth != null && (auth.uid === $uid || root.child('shaker/users').child(auth.uid).child('role').val() === 'admin')",
          ".write": "auth != null && (auth.uid === $uid || root.child('shaker/users').child(auth.uid).child('role').val() === 'admin')",
          ".validate": "newData.hasChildren(['uid','email','role'])",
          "role": { ".validate": "newData.val() === 'admin' || newData.val() === 'moderator'" }
        }
      },

      "chats": {
        "$modUid": {
          ".read":  "auth != null && (auth.uid === $modUid || root.child('shaker/users').child(auth.uid).child('role').val() === 'admin')",
          ".write": "auth != null && (auth.uid === $modUid || root.child('shaker/users').child(auth.uid).child('role').val() === 'admin')",
          "$msgId": {
            ".validate": "newData.hasChildren(['sender','text','time']) && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length <= 2000"
          }
        }
      },

      "logs": {
        ".read":  "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null",
        "$id": {
          ".validate": "newData.hasChildren(['uid','action','time']) && newData.child('uid').val() === auth.uid"
        }
      },

      "settings": {
        ".read":  "auth != null",
        ".write": "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin'"
      },

      "setup_done": {
        ".read":  true,
        ".write": "auth != null && !data.exists()"
      }
    },

    "shaker_backups": {
      ".read":  "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('shaker/users').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}